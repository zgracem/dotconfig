export MBOX=$HOME/.mail/mbox
export DEAD=$HOME/.mail/dead.letter

[ -z "$MAIL" ] && [ -r "/var/mail/$USER" ] && export MAIL="/var/mail/$USER"
[ -r "$XDG_CONFIG_HOME/mailcap/mailcap" ] && export MAILCAPS=$XDG_CONFIG_HOME/mailcap/mailcap

command -v nethack >/dev/null && command -v alpine >/dev/null || return
export MAILREADER="$HOME/.private/bin/nethack-mailreader"
